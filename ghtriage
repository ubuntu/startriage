# pylint: disable=invalid-name


"""Triage tool for GitHub-based projects."""

__example__ = """
Display issues and PRs for today's triage:

    $ ghtriage

Triage issues and pull requests for the example and foobar projects
created or updated so far this week:

    $ ghtriage --org canonical \
               --repo example \
               --repo foobar \
               Monday Today
"""
__version__ = "0.1"


import os
import sys
import argparse
import logging
import webbrowser
import json

from functools import lru_cache

from urllib.request import Request, urlopen
from urllib.error import HTTPError, URLError
from datetime import datetime, timedelta

logging.basicConfig(
    level=logging.INFO,
    format='%(levelname)s: %(message)s',
    stream=sys.stderr
)


# Constants for ANSI codes
OSC8 = "\u001b]8"
ST = "\u001b\\"

@lru_cache
def ansi_hyperlink(url: str, text: str) -> str:
    """Format text into a hyperlink using ANSI escape codes.

    :ref: https://iterm2.com/documentation-escape-codes.html
    :ref: https://gist.github.com/egmontkob/eb114294efbcd5adb1944c9f3cb5feda

    :param str url: The linked action to load in a web browser.
    :param str text: The visible text to show.
    :rtype: str
    :returns: ANSI escape code sequence to display the hyperlink.
    """
    # Check if stdout is a TTY (interactive terminal)
    if os.isatty(sys.stdout.fileno()):
        return f"{OSC8};;{url}{ST}{text}{OSC8};;{ST}"
    return text


def parse_date_input(date_string: str, relative_to: datetime = None) -> datetime:
    """Parses a date string according to a few basic formats.

    This takes date strings supporting formats like YYYY-MM-DD, 'today',
    'yesterday', day names like 'Monday', and simple relative phrases
    like 'N days ago'.

    :param date_string: The string to parse.
    :param relative_to: The datetime object to calculate relative dates from.
        Defaults to today if None.

    :raises ValueError: If the date_string cannot be parsed.

    :returns: A datetime object representing the parsed date (at midnight).
    :rtype: datetime
    """
    if relative_to is None:
        relative_to = datetime.now()

    # Normalize relative_to to midnight for consistent calculations
    relative_to = relative_to.replace(hour=0, minute=0, second=0, microsecond=0)

    # 1. YYYY-MM-DD
    try:
        return datetime.strptime(date_string, '%Y-%m-%d')
    except ValueError:
        pass  # Not a YYYY-MM-DD format, try other methods

    # 2. Specific relative keywords
    date_string_lower = date_string.lower()
    if date_string_lower == "today":
        return relative_to
    elif date_string_lower == "yesterday":
        return relative_to - timedelta(days=1)

    # 3. Day names (most recent past or current occurrence)
    day_names = {
        "monday": 0, "tuesday": 1, "wednesday": 2, "thursday": 3,
        "friday": 4, "saturday": 5, "sunday": 6
    }
    if date_string_lower in day_names:
        target_weekday = day_names[date_string_lower]
        current_weekday = relative_to.weekday()  # Monday is 0, Sunday is 6

        # Calculate days difference to get to the target weekday
        # (current_weekday - target_weekday + 7) % 7 calculates how many days back
        # to go to reach the *most recent* occurrence of target_weekday.
        # If today is Wednesday (2) and target is Monday (0),
        # diff = (2-0+7)%7 = 2. Go back 2 days.
        # If today is Monday (0) and target is Monday (0),
        # diff = (0-0+7)%7 = 0. Stay on current day.
        days_diff = (current_weekday - target_weekday + 7) % 7
        return relative_to - timedelta(days=days_diff)

    # 4. Limited natural language (e.g., "N days ago", "N weeks ago", "last X")
    parts = date_string_lower.split()
    if len(parts) == 3 and parts[2] == "ago":
        try:
            num = int(parts[0])
            unit = parts[1].rstrip('s')
            if unit == "day":
                return relative_to - timedelta(days=num)
            elif unit == "week":
                return relative_to - timedelta(weeks=num)
        except ValueError:
            pass  # Not a valid number or unit
    elif len(parts) == 2 and parts[0] == "last":
        # "Last monday" means the Monday of the *previous* week,
        # always at least 7 days ago, distinct from "Monday" which can be today.
        target_weekday = day_names.get(parts[1])
        if target_weekday is not None:
            current_weekday = relative_to.weekday()
            # Calculate days back to the target weekday in the *previous* week.
            days_diff = (current_weekday - target_weekday + 7) % 7
            days_diff += 7
            return relative_to - timedelta(days=days_diff)

    raise ValueError(
        f"'{date_string}' is not a recognized date format. "
        f"Expected YYYY-MM-DD, 'today', 'yesterday', a day name "
        f"(e.g., 'monday'), last DAYNAME, or 'N days/weeks ago'.")


def create_arg_parser() -> argparse.ArgumentParser:
    """Sets up the command line parser object.

    :returns: parser object, ready to run <parser>.parse_args().
    :rtype: argparse.ArgumentParser
    """
    progname = "ghtriage"
    parser = argparse.ArgumentParser(
        prog=progname,
        description=__doc__,
        formatter_class=argparse.RawTextHelpFormatter,
        epilog=__example__)

    parser.add_argument(
        'start_date',
        action='store',
        nargs='?',
        default=None,
        help=(
            "Optional date or day name to start finding comments (e.g. 2022-04-13, "
            "monday, Thu).  Defaults to today if not provided."
        ))
    parser.add_argument(
        'end_date',
        action='store',
        nargs='?',  # Makes end_date optional
        help="Date to end finding comments (inclusive) (e.g. 2022-04-27)")

    parser.add_argument(
        '-D', '--debug',
        dest='debug',
        action='store_true',
        help="Turn on general debugging output")
    parser.add_argument(
        '-o', '--open-in-browser', '--open',
        dest='open_in_browser',
        action='store_true',
        help="Open comments/PRs/issues in web browser (placeholder)")
    parser.add_argument(
        '--full-urls', '--fullurls',
        dest='full_urls',
        action='store_true',
        help="Show full URLs instead of shortcuts (placeholder)")

    parser.add_argument(
        '-O', '--org', '--organization',
        dest='organization',
        action='store',
        default=None,
        help="GitHub organization (e.g., 'canonical') (placeholder)")
    parser.add_argument(
        '-R', '--repo', '--repository',
        dest='repositories',
        action='append',
        default=[],
        help="GitHub repository name (can be specified multiple times) "
             "(placeholder)")

    parser.add_argument(
        '-V', '--version',
        action='version',
        version=f'%(prog)s {__version__}',
        help="Version information")

    return parser


def make_github_api_request(url: str) -> dict:
    """Makes a GET request to the GitHub API and returns the JSON response.

    :param url: The full URL for the GitHub API endpoint.

    :raises HTTPError: For HTTP errors (e.g., 404, 403).
    :raises URLError: For network-related errors (e.g., no internet).
    :raises json.JSONDecodeError: If the response is not valid JSON.

    :returns: A dictionary representing the JSON response.
    :rtype: dict
    """
    headers = {
        'Accept': 'application/vnd.github.v3+json',
        'User-Agent': 'ghtriage-script/1.0',
    }
    req = Request(url, headers=headers)

    try:
        with urlopen(req) as response:
            if response.status == 200:
                return json.loads(response.read().decode('utf-8'))
            else:
                raise HTTPError(
                    url, response.status,
                    f"Unexpected status: {response.status}",
                    response.headers, None
                )
    except HTTPError as e:
        logging.error("HTTP Error: %s - %s for URL: %s" %(e.code, e.reason, url))
        raise
    except URLError as e:
        logging.error(f"URL Error: {e.reason} for URL: {url}.")
        raise
    except json.JSONDecodeError as e:
        logging.error(f"Failed to decode JSON response from {url}: {e}")
        raise


def main(args: argparse.Namespace) -> int:
    """Main entrypoint for the command.

    :param args: Command line arguments.

    :returns: Status code OK (0) on success, non-zero on error.
    :rtype: int
    """
    # Configure logging level based on debug flag
    if args.debug:
        logging.getLogger().setLevel(logging.DEBUG)

    logging.debug("Parsed Arguments:")
    logging.debug(vars(args))

    # Default start_date to 'today' if not provided
    if args.start_date is None:
        args.start_date = "today"

    try:
        parsed_start_date = parse_date_input(args.start_date)
    except ValueError as e:
        logging.error(f"Invalid start_date: {e}")
        sys.exit(os.EX_USAGE)

    if args.end_date:
        try:
            parsed_end_date = parse_date_input(args.end_date)
        except ValueError as e:
            logging.error(f"Invalid end_date: {e}")
            sys.exit(os.EX_USAGE)
    else:
        # If end_date is not provided, it's the same as start_date (inclusive for one day)
        parsed_end_date = parsed_start_date

    # Ensure parsed dates are formatted for the GitHub URL (YYYY-MM-DD)
    start_date_str = parsed_start_date.strftime('%Y-%m-%d')
    end_date_str = parsed_end_date.strftime('%Y-%m-%d')
    date_range_for_url = f"{start_date_str}..{end_date_str}"

    projects_to_triage = []
    if args.organization and args.repositories:
        for repo_name in args.repositories:
            projects_to_triage.append({
                "name": f"{args.organization}/{repo_name}",
                "org": args.organization,
                "repo": repo_name
            })
    elif args.organization and not args.repositories:
        logging.error("If --org is specified, at least one --repo must also be specified.")
        sys.exit(os.EX_USAGE)
    elif not args.organization and args.repositories:
        logging.error("If --repo is specified, --org must also be specified.")
        sys.exit(os.EX_USAGE)
    else:
        # Default projects
        projects_to_triage = [
            {
                "name": "UMH Triage",
                "org": "canonical",
                "repo": "ubuntu-maintainers-handbook"
            },
            {
                "name": "Ubuntu Server Guide Triage",
                "org": "canonical",
                "repo": "ubuntu-server-documentation"
            },
        ]

    for project in projects_to_triage:
        print(f"\n### {project['name']} ({date_range_for_url}) ###")
        base_url = f"https://api.github.com/repos/{project['org']}/{project['repo']}"

        pulls_url = f"{base_url}/pulls?state=open&sort=updated&direction=desc"
        logging.debug(f"Fetching PRs from: {pulls_url}")
        try:
            pull_requests = make_github_api_request(pulls_url)
            filtered_prs = []
            for pr in pull_requests:
                created_at = datetime.strptime(
                    pr['created_at'], '%Y-%m-%dT%H:%M:%SZ'
                ).replace(hour=0, minute=0, second=0, microsecond=0)
                updated_at = datetime.strptime(
                    pr['updated_at'], '%Y-%m-%dT%H:%M:%SZ'
                ).replace(hour=0, minute=0, second=0, microsecond=0)

                if (parsed_start_date <= created_at <= parsed_end_date) or \
                   (parsed_start_date <= updated_at <= parsed_end_date):
                    filtered_prs.append(pr)

            if filtered_prs:
                print(f"\nNew or Updated Pull Requests:")
                for pr in filtered_prs:
                    clickable_pr_number = ansi_hyperlink(pr['html_url'], f"#{pr['number']}")
                    print(f"* PR {clickable_pr_number}: {pr['title']}")
                    if args.full_urls:
                        print(f"  - {pr['html_url']}")

                    logging.debug(f"  HTML URL: {pr['html_url']}")
                    if args.open_in_browser:
                        webbrowser.open_new_tab(pr['html_url'])
                    logging.debug(
                        f"  Created: {pr['created_at']}, "
                        f"Updated: {pr['updated_at']}"
                    )
            else:
                print(f"\nNo new or updated PRs.")
        except (HTTPError, URLError, json.JSONDecodeError):
            # Error already logged in make_github_api_request
            pass

        issues_url = f"{base_url}/issues?state=open&sort=updated&direction=desc"
        logging.debug(f"Fetching Issues from: {issues_url}")
        try:
            issues = make_github_api_request(issues_url)
            filtered_issues = []
            for issue in issues:
                if 'pull_request' in issue:
                    logging.debug(f"Skipping PR masquerading as issue: {issue['html_url']}")
                    continue

                created_at = datetime.strptime(
                    issue['created_at'], '%Y-%m-%dT%H:%M:%SZ'
                ).replace(hour=0, minute=0, second=0, microsecond=0)
                updated_at = datetime.strptime(
                    issue['updated_at'], '%Y-%m-%dT%H:%M:%SZ'
                ).replace(hour=0, minute=0, second=0, microsecond=0)

                if (parsed_start_date <= created_at <= parsed_end_date) or \
                   (parsed_start_date <= updated_at <= parsed_end_date):
                    filtered_issues.append(issue)

            if filtered_issues:
                print(f"\nNew or Updated Issues:")
                for issue in filtered_issues:
                    clickable_issue_number = ansi_hyperlink(issue['html_url'], f"#{issue['number']}")
                    print(f"* Issue {clickable_issue_number}: {issue['title']}")
                    if args.full_urls:
                        print(f"  - {issue['html_url']}")

                    if args.open_in_browser:
                        webbrowser.open_new_tab(issue['html_url'])
                    logging.debug(f"  URL: ({issue['html_url']})")
                    logging.debug(
                        f"  Created: {issue['created_at']}, "
                        f"Updated: {issue['updated_at']}"
                    )
            else:
                print(f"\nNo new or updated issues.")
            print()
        except (HTTPError, URLError, json.JSONDecodeError):
            # Error already logged in make_github_api_request
            pass

    return os.EX_OK


if __name__ == "__main__":
    # Option handling
    parser = create_arg_parser()
    args = parser.parse_args()

    retval = main(args)
    if retval == os.EX_USAGE:
        print()
        parser.print_help()
    sys.exit(retval)
